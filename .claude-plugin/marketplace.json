{
  "name": "superplanners-marketplace",
  "displayName": "SuperPlanners Marketplace",
  "description": "SuperPlanners 插件市场",
  "version": "0.1.0",
  "plugins": [
    {
      "name": "superplanners",
      "displayName": "SuperPlanners",
      "description": "智能任务分解与管理系统 - 将复杂需求自动拆解为可执行的任务计划",
      "version": "0.1.0",
